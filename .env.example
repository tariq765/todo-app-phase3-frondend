# Environment variables for the frontend
# Copy this file to .env.local for local development
# For Vercel deployment, set these in the Vercel dashboard

# Backend API URL - Replace with your Hugging Face backend URL
NEXT_PUBLIC_API_URL=https://your-huggingface-app-url.hf.space

# Example:
# NEXT_PUBLIC_API_URL=https://your-username.hf.space
# or if you're using a custom domain:
# NEXT_PUBLIC_API_URL=https://your-custom-domain.com